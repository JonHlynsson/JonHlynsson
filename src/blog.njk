---
layout: layouts/base.njk
title: Blog
description: Writing on clinical psychology, digital mental health, and endurance sport.
permalink: /blog/
---
<h1 class="page-title">Blog</h1>
<ul class="post-list">
  {% for post in collections.posts %}
  <li>
    <span class="post-meta"><time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time></span>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <p>{{ post.data.description or (post.templateContent | excerpt) }}</p>
  </li>
  {% endfor %}
</ul>
